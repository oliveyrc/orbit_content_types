<?php

/**
 * @file
 * Install, update and uninstall functions for the orbit_content_types module.
 */

declare(strict_types=1);

use Drupal\Core\Url;
use Drupal\node\Entity\Node;

/**
 * Implements hook_install().
 */
function orbit_content_types_install() {
  _orbit_content_types_create_dummy_page();
  _orbit_content_types_create_404_page();
}

/**
 * Implements hook_uninstall().
 */
function orbit_content_types_uninstall($is_syncing) {
  $config = \Drupal::configFactory()
    ->getEditable('orbit.settings');

  // Delete dummy page.
  $node = Node::load($config->get('dummy_page_nid'));
  $node->delete();

  // Delete/remove any config settings.
  $config = \Drupal::configFactory()
    ->getEditable('orbit.settings')
    ->delete();
}

